# Copy this file to .env and fill in your own API keys.
# Never commit .env.

# LLM backend: doubao | qianfan | aliyun | openai | ollama
LLM_PROVIDER=doubao

# Doubao / Volcengine Ark
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-your-endpoint-id
DOUBAO_API_KEY=your_doubao_api_key

# Optional LLM network settings
LLM_HTTP_PROXY=
LLM_HTTPS_PROXY=
LLM_VERIFY_SSL=true

# Aliyun DashScope compatible API
ALI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALI_MODEL=qwen-plus
ALI_API_KEY=your_aliyun_api_key

# Baidu Qianfan
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key

# OpenAI compatible API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=your_openai_api_key

# Ollama local model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b

# Baidu AI Search
BAIDU_SEARCH_API_KEY=your_baidu_search_api_key
BAIDU_SEARCH_RECENCY=month

# Search throttling
SEARCH_DELAY_SECONDS=2.0
